# CollabSpace Environment Variables
# Copy this file to .env.local and fill in your credentials.

# Convex — Get from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk — Get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Webhook — Set up in Clerk Dashboard > Webhooks
# Also add this to Convex Dashboard > Environment Variables
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Convex Dashboard Environment Variables (NOT in .env.local) ---
# These must be set in the Convex Dashboard > Settings > Environment Variables:
#
# CLERK_JWT_ISSUER_DOMAIN=https://your-domain.clerk.accounts.dev
# CLERK_WEBHOOK_SECRET=whsec_...
